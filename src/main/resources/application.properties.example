spring.application.name=FIFAFanWallet
spring.datasource.driver-class-name=org.postgresql.Driver
spring.jpa.hibernate.ddl-auto=update
server.servlet.session.cookie.same-site=Strict

#TO BE CHANGED
spring.datasource.url=DATABASE_URL
spring.datasource.username=DATABASE_USERNAME
spring.datasource.password=DATABASE_PASSWORD
jwt.secret=JWT_SECRET
jwt.refresh-expiration=JWT_REFRESH_EXPIRATION_MS

# Email (SMTP) Configuration
spring.mail.host=SMTP_HOST
spring.mail.port=SMTP_PORT
spring.mail.username=SMTP_USERNAME
spring.mail.password=SMTP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Frontend URL (for generating the verification link)
frontend.url=FRONTEND_URL

# Comma-separated browser origins allowed to call the API (Amplify URL, custom domain, local dev)
cors.allowed-origins=http://localhost:5173

